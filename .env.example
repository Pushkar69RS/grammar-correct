# Flask
FLASK_ENV=development
FLASK_DEBUG=true
MAX_INPUT_CHARS=5000

# AWS
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
# Prefer AWS CLI profiles or IAM roles. If you must use local keys, keep them in
# your private .env file only and never commit them to Git.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Amazon Bedrock
# Default model uses the Amazon Nova InvokeModel request shape in app.py.
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_MAX_TOKENS=1000
BEDROCK_TEMPERATURE=0.2
BEDROCK_READ_TIMEOUT=60
